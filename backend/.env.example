# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/buscot
MONGODB_TEST_URI=mongodb://localhost:27017/buscot-test

# JWT Tokens
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here
REFRESH_TOKEN_EXPIRY=30d

# Payment Gateway (Stripe/Razorpay)
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Business Details
BUSINESS_NAME=Buscot
BUSINESS_EMAIL=contact@buscot.in
BUSINESS_PHONE=+91-9876543210
BUSINESS_ADDRESS=Surat, Gujarat, India
BUSINESS_LOGO=https://your-cdn.com/logo.png

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
